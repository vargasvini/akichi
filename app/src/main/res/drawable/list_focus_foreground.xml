<?xml version="1.0" encoding="utf-8"?>
<!-- Foreground for focusable flat list rows (no rounded corners): a clear accent
     border + tint when focused via D-pad, so it's obvious which row is selected. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#337C5CFF" />
            <stroke android:width="2dp" android:color="@color/accent" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#447C5CFF" />
        </shape>
    </item>
    <item android:drawable="@android:color/transparent" />
</selector>
