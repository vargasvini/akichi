<?xml version="1.0" encoding="utf-8"?>
<!-- Foreground for focusable cards: a clear accent ring + tint when focused via D-pad,
     so it's obvious which card the controller has selected on a TV. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#337C5CFF" />
            <stroke android:width="3dp" android:color="@color/accent" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#447C5CFF" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item android:drawable="@android:color/transparent" />
</selector>
